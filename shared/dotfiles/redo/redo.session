# Set the layout for the current tab
layout tall

new_tab Vim
cd ~/code/redo
launch bash -ic "nvim; bash"

new_tab Services
cd ~/code/redo
launch bash -ic "bazel run service-manager -- --y; bash"

new_tab Terminal
cd ~/code/redo
launch bash

new_tab Claude
cd ~/code/redo
launch bash -ic "claude; bash"
